# Ignore directories generated by Composer
/drush/contrib/
/vendor/
/bin
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/profiles/varbase/
/web/recipes/contrib/
/recipes/
console/

# Ignore sensitive information
/web/sites/*/settings.local.php

# Ignore Drupal's file directory
/web/sites/*/files/

# Ignore SimpleTest multi-site environment
/web/sites/simpletest

# Ignore files generated by common IDEs
/.idea/

# Ignore .env files as they are personal
/.env

# Ignore paths that contain user-generated content
web/files
web/sites/*/files
web/sites/*/private
web/sites/*/settings.local.php
web/*/settings.local.php
acquia-file
/log

# Ignore vim swp files and gedit temp files
*.swp
*.*~
.vim

# Eclipse settings files
.project
.pydevproject
.settings
.buildpath

# NetBeans settings files
nbproject

# Ignore OS settings files
.DS_Store*
Thumbs.db
ehthumbs.db

# Ignore files generated by PhpStorm
.idea

# Server stuff
.bash_history
.bashrc
errors.log

# Node.js dependencies
/node_modules
/web/**/node_modules

# Yarn cache and build artifacts
.yarn/*
.pnp.*

# Ignore mounts
web/sites/default/files
tmp
private
.drush
drush-backups
.console
/.editorconfig
/.gitattributes
/bin/*

# Storybook build output and dev env file
/storybook
/.env.storybook

# Ignore common AI assistant metadata
CLAUDE.md
CURSOR.md

.claude/
.cursor/
.copilot*
.gemini/
.codex/
.warp/
.playwright-mcp
.easy_encryption
